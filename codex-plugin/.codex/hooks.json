{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "<HOME>/.codex/hooks/capture-prompt.sh",
            "timeout": 5,
            "statusMessage": "Bash Script Logger: capturing prompt..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "<HOME>/.codex/hooks/log-bash.sh",
            "timeout": 10,
            "statusMessage": "Bash Script Logger: logging bash command..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "<HOME>/.codex/hooks/capture-context.sh",
            "timeout": 15,
            "statusMessage": "Bash Script Logger: capturing file context..."
          }
        ]
      }
    ]
  }
}